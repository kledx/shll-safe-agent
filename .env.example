# SafeAgent Environment Configuration
# Copy to .env and fill in your values

# Required: WDK seed phrase for wallet operations
WDK_SEED="your twelve word seed phrase here"

# Required: OpenAI API key for LLM reasoning
OPENAI_API_KEY="sk-..."

# Optional: SHLL operator private key (for live PolicyGuard checks)
# For live safe_swap runs, this should resolve to the same operator wallet as WDK_SEED.
RUNNER_PRIVATE_KEY="0x..."

# Optional: SHLL Agent token ID
SHLL_TOKEN_ID="20"

# Optional: Custom BSC RPC
BSC_RPC="https://bsc-dataseed1.binance.org"

# Optional: Custom WDK MCP server entrypoint
# Default is the versioned local server in src/wdk-bsc-server/index.js
WDK_SERVER_PATH="src/wdk-bsc-server/index.js"

# Optional: Auto-confirm WDK / SHLL MCP write prompts for autonomous runs
AUTO_CONFIRM_WRITES="true"

# Optional: WDK Indexer API key
WDK_INDEXER_API_KEY=""
